{
  "name": "@unisat/wallet-shared",
  "version": "0.1.2",
  "description": "Shared type definitions for UniSat wallet ecosystem",
  "main": "lib/index.js",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "files": [
    "lib/**/*",
    "src/**/*",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "require": "./lib/index.js",
      "import": "./lib/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rm -rf lib coverage",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "yarn clean && yarn build"
  },
  "keywords": [
    "wallet",
    "types",
    "typescript",
    "bitcoin",
    "crypto",
    "unisat",
    "blockchain"
  ],
  "author": "UniSat",
  "license": "MIT",
  "dependencies": {
    "@unisat/wallet-types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "@vitest/coverage-v8": "^0.34.0",
    "@vitest/ui": "^0.34.0",
    "eslint": "^8.50.0",
    "tsup": "^7.2.0",
    "typescript": "^5.2.0",
    "vitest": "^0.34.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/unisat-wallet/wallet-toolkit.git",
    "directory": "packages/wallet-shared"
  },
  "bugs": {
    "url": "https://github.com/unisat-wallet/wallet-toolkit/issues"
  },
  "homepage": "https://github.com/unisat-wallet/wallet-toolkit/tree/main/packages/wallet-shared#readme",
  "publishConfig": {
    "access": "public"
  }
}

{
  "name": "@unisat/wallet-connect",
  "version": "0.2.0",
  "description": "Web3 wallet connection library for Bitcoin wallets (UniSat, OKX, Xverse)",
  "main": "lib/index.js",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "files": [
    "lib/**/*",
    "src/**/*",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "require": "./lib/index.js",
      "import": "./lib/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.js",
    "clean": "rm -rf lib",
    "dev": "tsup --watch",
    "prepublishOnly": "yarn clean && yarn build"
  },
  "keywords": [
    "bitcoin",
    "wallet",
    "web3",
    "unisat",
    "okx",
    "xverse",
    "connect",
    "psbt",
    "ordinals",
    "runes",
    "typescript"
  ],
  "author": "UniSat",
  "license": "MIT",
  "peerDependencies": {
    "sats-connect": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "sats-connect": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "eslint": "^8.50.0",
    "sats-connect": "^2.8.0",
    "tsup": "^7.2.0",
    "typescript": "^5.2.0",
    "vitest": "^0.34.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/unisat-wallet/wallet-toolkit.git",
    "directory": "packages/wallet-connect"
  },
  "bugs": {
    "url": "https://github.com/unisat-wallet/wallet-toolkit/issues"
  },
  "homepage": "https://github.com/unisat-wallet/wallet-toolkit/tree/main/packages/wallet-connect#readme",
  "publishConfig": {
    "access": "public"
  }
}

{
  "name": "@unisat/babylon-service",
  "version": "1.0.0",
  "description": "Babylon Bitcoin staking service for UniSat Wallet - handles delegation management and API interactions",
  "main": "lib/index.js",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "files": [
    "lib/**/*",
    "src/**/*",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "require": "./lib/index.js",
      "import": "./lib/index.mjs"
    },
    "./types": {
      "types": "./lib/types.d.ts",
      "require": "./lib/types.js",
      "import": "./lib/types.mjs"
    },
    "./cosmos": {
      "types": "./lib/cosmos.d.ts",
      "require": "./lib/cosmos.js",
      "import": "./lib/cosmos.mjs"
    },
    "./api": {
      "types": "./lib/api.d.ts",
      "require": "./lib/api.js",
      "import": "./lib/api.mjs"
    },
    "./utils": {
      "types": "./lib/utils.d.ts",
      "require": "./lib/utils.js",
      "import": "./lib/utils.mjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.js",
    "clean": "rm -rf lib",
    "dev": "tsup --watch",
    "prepublishOnly": "yarn clean && yarn build"
  },
  "keywords": [
    "babylon",
    "bitcoin",
    "staking",
    "delegation",
    "blockchain",
    "unisat",
    "wallet",
    "typescript"
  ],
  "author": "UniSat",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "qs": "^6.11.0",
    "@babylonlabs-io/babylon-proto-ts": "0.0.3-canary.5",
    "@cosmjs/proto-signing": "^0.33.0",
    "@cosmjs/stargate": "^0.33.0",
    "@cosmjs/crypto": "^0.33.0",
    "@cosmjs/tendermint-rpc": "^0.33.0",
    "@cosmjs/encoding": "^0.33.0",
    "bech32": "^2.0.0",
    "buffer": "^6.0.3",
    "cosmjs-types": "^0.9.0",
    "@noble/curves": "^1.2.0",
    "@noble/hashes": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/qs": "^6.9.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "eslint": "^8.50.0",
    "tsup": "^7.2.0",
    "typescript": "^5.2.0",
    "vitest": "^0.34.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/unisat-wallet/wallet-toolkit.git",
    "directory": "packages/babylon-service"
  },
  "bugs": {
    "url": "https://github.com/unisat-wallet/wallet-toolkit/issues"
  },
  "homepage": "https://github.com/unisat-wallet/wallet-toolkit/tree/main/packages/babylon-service#readme",
  "publishConfig": {
    "access": "public"
  }
}

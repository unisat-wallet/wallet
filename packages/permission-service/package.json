{
  "name": "@unisat/permission-service",
  "version": "0.1.10",
  "description": "Cross-platform permission management service for web3 applications",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./adapters": {
      "require": "./dist/adapters/index.js",
      "import": "./dist/adapters/index.mjs",
      "types": "./dist/adapters/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "cd ../.. && npx vitest packages/permission-service/test",
    "test:run": "cd ../.. && npx vitest run packages/permission-service/test",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "bitcoin",
    "permission",
    "web3",
    "wallet",
    "browser-extension",
    "dapp",
    "connected-sites"
  ],
  "author": "UniSat Team",
  "license": "MIT",
  "dependencies": {
    "@unisat/wallet-types": "workspace:*",
    "lru-cache": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^7.0.0",
    "typescript": "^5.0.0",
    "vitest": "^0.34.0"
  },
  "publishConfig": {
    "access": "public"
  }
}

{
  "name": "@unisat/wallet-bitcoin",
  "version": "1.0.1",
  "description": "Bitcoin core utilities for UniSat wallet ecosystem",
  "main": "lib/index.js",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "files": [
    "lib/**/*",
    "src/**/*",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "require": "./lib/index.js",
      "import": "./lib/index.mjs"
    },
    "./browser": "./lib/browser/index.global.js"
  },
  "scripts": {
    "build": "tsup",
    "build:browser": "tsup --config tsup.browser.config.ts",
    "build:all": "pnpm build && pnpm run build:browser",
    "build:watch": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint src test --ext .ts,.js",
    "lint:fix": "eslint src test --ext .ts,.js --fix",
    "clean": "rm -rf lib coverage",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm clean && pnpm run build:all && pnpm test"
  },
  "keywords": [
    "bitcoin",
    "wallet",
    "crypto",
    "blockchain",
    "unisat",
    "bitcoinjs",
    "secp256k1",
    "ecdsa",
    "schnorr",
    "typescript"
  ],
  "author": "UniSat",
  "license": "MIT",
  "dependencies": {
    "@bitcoinerlab/secp256k1": "^1.0.5",
    "@noble/hashes": "^1.1.5",
    "@noble/secp256k1": "^1.7.1",
    "@unisat/wallet-types": "workspace:*",
    "bitcoinjs-lib": "^6.1.5",
    "ecpair": "^2.1.0",
    "tiny-secp256k1": "^2.2.3",
    "varuint-bitcoin": "^1.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "@vitest/coverage-v8": "^0.34.0",
    "@vitest/ui": "^0.34.0",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.1",
    "eslint": "^8.50.0",
    "stream-browserify": "^3.0.0",
    "tsup": "^7.2.0",
    "typescript": "^5.2.0",
    "vitest": "^0.34.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/unisat-wallet/wallet-toolkit.git",
    "directory": "packages/wallet-bitcoin"
  },
  "bugs": {
    "url": "https://github.com/unisat-wallet/wallet-toolkit/issues"
  },
  "homepage": "https://github.com/unisat-wallet/wallet-toolkit/tree/main/packages/wallet-bitcoin#readme",
  "publishConfig": {
    "access": "public"
  }
}

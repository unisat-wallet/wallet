{
  "name": "@unisat/i18n",
  "version": "1.0.0",
  "description": "Internationalization (i18n) utilities for UniSat applications",
  "main": "lib/index.js",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "files": [
    "lib/**/*",
    "src/**/*",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "require": "./lib/index.js",
      "import": "./lib/index.mjs"
    },
    "./loaders": {
      "types": "./lib/loaders/index.d.ts",
      "require": "./lib/loaders/index.js",
      "import": "./lib/loaders/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "clean": "rm -rf lib",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "yarn clean && yarn build"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "localization",
    "translation",
    "unisat",
    "bitcoin",
    "wallet"
  ],
  "author": "UniSat Team",
  "license": "MIT",
  "dependencies": {
    "loglevel": "^1.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "eslint": "^8.50.0",
    "tsup": "^7.2.0",
    "typescript": "^5.2.0",
    "vitest": "^0.34.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/unisat-wallet/wallet-toolkit.git",
    "directory": "packages/i18n"
  },
  "bugs": {
    "url": "https://github.com/unisat-wallet/wallet-toolkit/issues"
  },
  "homepage": "https://github.com/unisat-wallet/wallet-toolkit/tree/main/packages/i18n#readme",
  "publishConfig": {
    "access": "public"
  }
}
{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./lib/types",
    "rootDir": "./src",
    "declaration": true,
    "emitDeclarationOnly": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "test/**/*",
    "lib/**/*",
    "node_modules"
  ]
}
{
  "name": "@unisat/contact-book",
  "version": "1.1.0",
  "description": "Universal contact book management with multi-chain support",
  "main": "lib/index.js",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "files": [
    "lib/**/*",
    "src/**/*",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "require": "./lib/index.js",
      "import": "./lib/index.mjs"
    },
    "./types": {
      "types": "./lib/types.d.ts",
      "require": "./lib/types.js",
      "import": "./lib/types.mjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:run": "cd ../.. && npx vitest run packages/contact-book/test",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "bitcoin",
    "contact",
    "address",
    "wallet",
    "multi-chain",
    "unisat"
  ],
  "author": "UniSat Team",
  "license": "MIT",
  "dependencies": {
    "@unisat/wallet-types": "workspace:*",
    "@unisat/wallet-storage": "workspace:*"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@types/node": "^20.0.0",
    "tsup": "^7.0.0",
    "typescript": "^5.0.0",
    "vitest": "^0.34.0"
  },
  "publishConfig": {
    "access": "public"
  }
}

{
  "name": "@unisat/notification-service",
  "version": "1.0.0",
  "description": "Cross-platform permission management service for web3 applications",
  "main": "lib/index.js",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "files": [
    "lib/**/*",
    "src/**/*",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "require": "./lib/index.js",
      "import": "./lib/index.mjs"
    },
    "./types": {
      "types": "./lib/types.d.ts",
      "require": "./lib/types.js",
      "import": "./lib/types.mjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "cd ../.. && npx vitest packages/notification-service/test",
    "test:run": "cd ../.. && npx vitest run packages/notification-service/test",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "bitcoin",
    "permission",
    "web3",
    "wallet",
    "browser-extension",
    "dapp",
    "connected-sites"
  ],
  "author": "UniSat Team",
  "license": "MIT",
  "dependencies": {
    "eventemitter3": "^5.0.1",
    "@unisat/wallet-shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^7.0.0",
    "typescript": "^5.0.0",
    "vitest": "^0.34.0"
  },
  "publishConfig": {
    "access": "public"
  }
}

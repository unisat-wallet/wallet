{
  "name": "@unisat/wallet-state",
  "version": "1.0.6",
  "description": "Redux state management for UniSat wallet, shared between platforms",
  "main": "lib/index.js",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./lib/index.mjs",
      "require": "./lib/index.js",
      "types": "./lib/index.d.ts"
    },
    "./types": {
      "types": "./lib/types/index.d.ts",
      "require": "./lib/types/index.js",
      "import": "./lib/types/index.mjs"
    }
  },
  "files": [
    "lib/**/*",
    "src/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:cjs": "tsup --format cjs",
    "build:esm": "tsup --format esm",
    "build:typed": "tsc --declaration --declarationMap --emitDeclarationOnly --outDir lib",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@unisat/babylon-service": "workspace:*",
    "@unisat/base-utils": "workspace:*",
    "@unisat/keyring-service": "workspace:*",
    "@unisat/wallet-shared": "workspace:*",
    "@unisat/wallet-types": "workspace:*",
    "bignumber.js": "^9.1.2",
    "bip39": "^3.1.0",
    "loglevel": "^1.8.0",
    "react-redux": "8.0.1"
  },
  "peerDependencies": {
    "@reduxjs/toolkit": "^1.9.2",
    "compare-versions": "^4.1.3",
    "i18next": "^21.8.1",
    "react": "18.2.0",
    "react-i18next": "^11.16.9",
    "react-router-dom": "^6.3.0",
    "redux-localstorage-simple": "^2.5.1"
  },
  "devDependencies": {
    "@reduxjs/toolkit": "^1.9.2",
    "@testing-library/react": "^13.2.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "eslint": "^8.0.0",
    "jsdom": "^27.4.0",
    "react-dom": "18.2.0",
    "tsup": "^7.0.0",
    "typescript": "^5.0.0",
    "vitest": "^0.34.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
